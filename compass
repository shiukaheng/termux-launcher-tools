#!/usr/bin/env python3
"""Compass launcher with location geocoding"""

import subprocess
import sys
import urllib.parse
import urllib.request
import json


def geocode(location: str) -> tuple:
    """Get coordinates for a location name using Nominatim"""
    try:
        query = urllib.parse.quote(location)
        url = f"https://nominatim.openstreetmap.org/search?q={query}&format=json&limit=1"
        
        req = urllib.request.Request(url, headers={"User-Agent": "termux-compass/1.0"})
        with urllib.request.urlopen(req, timeout=10) as response:
            data = json.loads(response.read().decode())
        
        if data:
            lat = float(data[0]["lat"])
            lng = float(data[0]["lon"])
            display_name = data[0].get("display_name", location).split(",")[0]
            return lat, lng, display_name
    except Exception as e:
        print(f"Geocoding error: {e}", file=sys.stderr)
    return None, None, None


def launch_compass(lat: float = None, lng: float = None):
    """Launch compass app"""
    try:
        if lat is not None and lng is not None:
            cmd = ["am", "start", "-a", "android.intent.action.VIEW",
                   "-d", f"geo:{lat},{lng}"]
        else:
            cmd = ["am", "start", "-n", "com.compass/.MainActivity"]
        
        result = subprocess.run(cmd, capture_output=True, text=True)
        return result.returncode == 0
    except Exception as e:
        print(f"Error launching compass: {e}", file=sys.stderr)
        return False


def main():
    if len(sys.argv) < 2:
        print("Launching compass...")
        launch_compass()
        return
    
    location = " ".join(sys.argv[1:])
    print(f"Finding coordinates for: {location}")
    
    lat, lng, display_name = geocode(location)
    
    if lat is None:
        print(f"Could not find location: {location}", file=sys.stderr)
        print("Launching compass without target...")
        launch_compass()
        sys.exit(1)
    
    print(f"Found: {display_name}")
    print(f"Coordinates: {lat:.4f}, {lng:.4f}")
    print("Launching compass with waypoint...")
    launch_compass(lat, lng)


if __name__ == "__main__":
    main()
