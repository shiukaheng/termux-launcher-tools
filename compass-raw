#!/usr/bin/env python3
"""Compass launcher with direct coordinates"""

import subprocess
import sys


def launch_compass(lat: float, lng: float):
    """Launch compass app with coordinates"""
    try:
        cmd = ["am", "start", "-a", "android.intent.action.VIEW",
               "-d", f"geo:{lat},{lng}"]
        result = subprocess.run(cmd, capture_output=True, text=True)
        return result.returncode == 0
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        return False


def main():
    if len(sys.argv) != 3:
        print("Usage: compass-raw <lat> <lng>")
        print("Launch compass pointing toward coordinates.")
        print()
        print("Example:")
        print("  compass-raw 51.5074 -0.1278")
        sys.exit(1)
    
    try:
        lat = float(sys.argv[1])
        lng = float(sys.argv[2])
    except ValueError:
        print("Error: lat and lng must be numbers")
        sys.exit(1)
    
    print(f"Launching compass to {lat:.4f}, {lng:.4f}...")
    launch_compass(lat, lng)


if __name__ == "__main__":
    main()
