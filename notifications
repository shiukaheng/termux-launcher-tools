#!/usr/bin/env python3
"""Notification manager for Termux - exposes Android NotificationListenerService API"""

import json
import os
import subprocess
import sys


TERMUX_API = os.environ.get("PREFIX", "/data/data/com.termux/files/usr") + "/libexec/termux-api"


def run_termux_api(method: str, args: list = None) -> tuple:
    cmd = [TERMUX_API, method]
    if args:
        cmd.extend(args)
    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except FileNotFoundError:
        print("Error: termux-api not found. Install with: pkg install termux-api", file=sys.stderr)
        sys.exit(1)


def get_notifications() -> list:
    returncode, stdout, stderr = run_termux_api("NotificationList")
    if returncode != 0 or not stdout:
        return []
    try:
        return json.loads(stdout)
    except json.JSONDecodeError:
        return []


def list_notifications(verbose=False, show_keys=False):
    notifications = get_notifications()
    if not notifications:
        print("No notifications")
        return
    
    for i, n in enumerate(notifications):
        title = n.get("title", "")
        content = n.get("content", "")
        pkg = n.get("packageName", "")
        key = n.get("key", "")
        
        if title or content:
            display = f"{title}: {content}" if title else content
        else:
            display = f"[{pkg}]"
        
        display = display[:60] + "..." if len(display) > 60 else display
        
        if show_keys:
            print(f"[{key}] {display}")
        else:
            print(f"[{i}] {display}")
        
        actions = n.get("actions", [])
        has_content_intent = n.get("hasContentIntent", False)
        
        if verbose:
            print(f"    package: {pkg}")
            print(f"    key: {key}")
            if actions or has_content_intent:
                action_list = []
                if has_content_intent:
                    action_list.append("tap")
                for a in actions:
                    action_list.append(a.get("title", "?").lower())
                print(f"    actions: {', '.join(action_list)}")
        else:
            if actions or has_content_intent:
                action_list = []
                if has_content_intent:
                    action_list.append("tap")
                for a in actions:
                    title = a.get("title", "?")
                    action_list.append(f"[{title.lower()}]")
                print(f"    {' '.join(action_list)}")


def resolve_notification(identifier: str, use_keys: bool = False) -> dict:
    notifications = get_notifications()
    if not notifications:
        return None
    
    if use_keys:
        for n in notifications:
            if n.get("key") == identifier:
                return n
        return None
    else:
        try:
            idx = int(identifier)
            if idx < 0 or idx >= len(notifications):
                return None
            return notifications[idx]
        except ValueError:
            return None


def find_action(action_name: str, notification: dict) -> int:
    action_name = action_name.lower()
    
    if action_name == "tap":
        if notification.get("hasContentIntent", False):
            return 0
        return None
    
    actions = notification.get("actions", [])
    matches = []
    
    for i, a in enumerate(actions):
        title = a.get("title", "").lower()
        if title == action_name:
            return i + 1
        if action_name in title or title in action_name:
            matches.append((i + 1, title))
    
    if len(matches) == 1:
        return matches[0][0]
    elif len(matches) > 1:
        return matches
    
    return None


def cancel_notification(key: str = None, cancel_all: bool = False):
    args = []
    if cancel_all:
        args.extend(["--ez", "all", "true"])
    elif key:
        args.extend(["--es", "key", key])
    else:
        print("Error: No key specified", file=sys.stderr)
        return
    
    returncode, stdout, stderr = run_termux_api("NotificationCancel", args)
    if returncode == 0:
        print("Cancelled")
    else:
        print(stderr if stderr else "Failed to cancel")


def action_notification(key: str, action_idx: int, action_name: str):
    args = ["--es", "key", key, "--ei", "action", str(action_idx)]
    returncode, stdout, stderr = run_termux_api("NotificationAction", args)
    if returncode == 0:
        print(f"Action '{action_name}' sent")
    elif stderr:
        print(f"Error: {stderr}", file=sys.stderr)
        sys.exit(1)
    else:
        print("Error: Failed to send action (unknown error)", file=sys.stderr)
        sys.exit(1)


def show_usage():
    print("Usage: notifications <command> [args]")
    print()
    print("Commands:")
    print("  list [-v] [--keys]        List notifications")
    print("  tap [--keys] <id>         Tap notification")
    print("  cancel [--keys] <id|--all> Cancel notification(s)")
    print("  <action> [--keys] <id>    Fire action on notification")
    print()
    print("Options:")
    print("  --keys    Use stable key identifiers instead of indices")
    print()
    print("Examples:")
    print("  notifications list")
    print("  notifications list -v")
    print("  notifications list --keys")
    print("  notifications tap 1")
    print("  notifications tap --keys '0|com.example|123'")
    print("  notifications reply 1")
    print("  notifications cancel 1")
    print("  notifications cancel --all")


def parse_args(args: list) -> tuple:
    use_keys = "--keys" in args
    filtered_args = [a for a in args if a != "--keys"]
    return use_keys, filtered_args


def main():
    if len(sys.argv) < 2:
        show_usage()
        sys.exit(1)
    
    cmd = sys.argv[1].lower()
    
    if cmd == "list":
        verbose = "-v" in sys.argv or "--verbose" in sys.argv
        show_keys = "--keys" in sys.argv
        list_notifications(verbose, show_keys)
        return
    
    if cmd == "cancel":
        use_keys, args = parse_args(sys.argv[2:])
        
        if not args:
            print("Error: cancel requires an identifier or --all", file=sys.stderr)
            print("Usage: notifications cancel [--keys] <id|--all>", file=sys.stderr)
            sys.exit(1)
        
        if args[0] == "--all":
            cancel_notification(cancel_all=True)
            return
        
        identifier = args[0]
        n = resolve_notification(identifier, use_keys)
        
        if not n:
            if use_keys:
                print(f"Error: Key '{identifier}' not found", file=sys.stderr)
            else:
                notifications = get_notifications()
                max_idx = len(notifications) - 1 if notifications else 0
                print(f"Error: Index {identifier} out of range (0-{max_idx})", file=sys.stderr)
            sys.exit(1)
        
        key = n.get("key")
        if not key:
            print("Error: Notification has no key", file=sys.stderr)
            sys.exit(1)
        
        cancel_notification(key=key)
        return
    
    if cmd == "--help" or cmd == "-h":
        show_usage()
        return
    
    action_name = cmd
    use_keys, args = parse_args(sys.argv[2:])
    
    if not args:
        print(f"Error: '{action_name}' requires a notification identifier", file=sys.stderr)
        sys.exit(1)
    
    identifier = args[0]
    n = resolve_notification(identifier, use_keys)
    
    if not n:
        if use_keys:
            print(f"Error: Key '{identifier}' not found", file=sys.stderr)
        else:
            notifications = get_notifications()
            max_idx = len(notifications) - 1 if notifications else 0
            print(f"Error: Index {identifier} out of range (0-{max_idx})", file=sys.stderr)
        sys.exit(1)
    
    key = n.get("key")
    if not key:
        print("Error: Notification has no key", file=sys.stderr)
        sys.exit(1)
    
    result = find_action(action_name, n)
    
    if result is None:
        actions = n.get("actions", [])
        available = ["tap"] if n.get("hasContentIntent") else []
        available.extend(a.get("title", "?").lower() for a in actions)
        print(f"Error: Action '{action_name}' not found", file=sys.stderr)
        print(f"Available: {', '.join(available)}", file=sys.stderr)
        sys.exit(1)
    
    if isinstance(result, list):
        print(f"Error: Ambiguous action '{action_name}'", file=sys.stderr)
        print("Matches:", file=sys.stderr)
        for action_idx, title in result:
            print(f"  {title}", file=sys.stderr)
        sys.exit(1)
    
    action_notification(key, result, action_name)


if __name__ == "__main__":
    main()
