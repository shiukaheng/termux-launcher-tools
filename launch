#!/usr/bin/env python3
"""Fuzzy app launcher for Termux"""

import sys
import os

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from lib.apps import (
    load_index,
    search_apps,
    launch_app,
)


def main():
    args = sys.argv[1:]
    
    if not args:
        print("Usage: launch <app> [-a <activity>]")
        print("       launch --help")
        sys.exit(1)
    
    if args[0] == "--help":
        print("Usage: launch <app> [-a <activity>]")
        print()
        print("Launches an app by fuzzy name match.")
        print()
        print("Options:")
        print("  -a <activity>   Launch specific activity")
        print("                  Can be: index (1, 2), short name (SearchActivity),")
        print("                  or full name")
        print("  --debug         Show debug info")
        print("  --help          Show this help")
        print()
        print("Examples:")
        print("  launch google           # Launch Google")
        print("  launch google -a 2      # Launch activity #2")
        print("  launch google -a SearchActivity  # Launch by name")
        print()
        print("Use 'launchindexer' to list apps and activities.")
        sys.exit(0)
    
    debug = "--debug" in args
    if debug:
        args.remove("--debug")
    
    specific_activity = None
    if "-a" in args:
        idx = args.index("-a")
        if idx + 1 < len(args):
            specific_activity = args[idx + 1]
            args = args[:idx] + args[idx + 2:]
    
    if not args:
        print("Error: No app specified", file=sys.stderr)
        sys.exit(1)
    
    query = " ".join(args)
    
    index = load_index()
    if not index:
        print("No app index found. Run: launchindexer --reindex", file=sys.stderr)
        sys.exit(1)
    
    matches = search_apps(query, index)
    
    if not matches:
        print(f"No apps found matching '{query}'", file=sys.stderr)
        sys.exit(1)
    
    if len(matches) == 1 or matches[0]["ratio"] >= 0.8:
        app = matches[0]
        print(f"Launching: {app['label']}")
        if debug:
            print(f"[DEBUG] Package: {app['pkg']}")
            activities = app.get("activity") or []
            if isinstance(activities, str):
                activities = [activities]
            print(f"[DEBUG] Activities: {activities}")
        
        if specific_activity:
            activities = app.get("activity") or []
            if isinstance(activities, str):
                activities = [activities]
            
            if specific_activity.isdigit():
                idx = int(specific_activity) - 1
                if 0 <= idx < len(activities):
                    specific_activity = activities[idx]
                else:
                    print(f"Invalid activity index: {specific_activity}", file=sys.stderr)
                    sys.exit(1)
            elif "." not in specific_activity and activities:
                for act in activities:
                    if act.endswith("." + specific_activity) or act == specific_activity:
                        specific_activity = act
                        break
            
            launch_app(app["pkg"], [specific_activity], debug=debug)
        else:
            launch_app(app["pkg"], app.get("activity"), debug=debug)
    else:
        print(f"Multiple matches for '{query}':")
        for i, m in enumerate(matches[:3]):
            print(f"  [{i + 1}] {m['label']} ({m['pkg']}) - {m['ratio']:.0%} match")
        
        try:
            choice = input("Select (1-3) or Enter to cancel: ").strip()
            if choice in ("1", "2", "3"):
                idx = int(choice) - 1
                if idx < len(matches):
                    app = matches[idx]
                    print(f"Launching: {app['label']}")
                    launch_app(app["pkg"], app.get("activity"), debug=debug)
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled")


if __name__ == "__main__":
    main()
