#!/usr/bin/env python3
"""Fuzzy app launcher for Termux"""

import sys
import os

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from lib.apps import (
    load_index,
    index_apps,
    search_apps,
    launch_app,
    list_apps,
    get_app_index_path
)


def main():
    args = sys.argv[1:]
    
    if not args:
        print("Usage: launch <app name>")
        print("       launch <app name> --activity <activity>")
        print("       launch --activities <app name>")
        print("       launch --reindex [--debug]")
        print("       launch --list [filter]")
        sys.exit(1)
    
    debug = "--debug" in args
    if debug:
        args.remove("--debug")
    
    if args[0] == "--reindex":
        print("Indexing apps...")
        index = index_apps(debug=debug)
        print(f"Indexed {len(index['apps'])} apps")
        sys.exit(0)
    
    if args[0] == "--list":
        index = load_index()
        if not index:
            print("No app index found. Run: launch --reindex", file=sys.stderr)
            sys.exit(1)
        
        filter_str = args[1] if len(args) > 1 else None
        apps = list_apps(index, filter_str)
        
        for app in apps:
            print(f"{app['label']} ({app['pkg']})")
        sys.exit(0)
    
    if args[0] == "--activities":
        if len(args) < 2:
            print("Usage: launch --activities <app name>", file=sys.stderr)
            sys.exit(1)
        
        index = load_index()
        if not index:
            print("No app index found. Run: launch --reindex", file=sys.stderr)
            sys.exit(1)
        
        query = " ".join(args[1:])
        matches = search_apps(query, index)
        
        if not matches:
            print(f"No apps found matching '{query}'", file=sys.stderr)
            sys.exit(1)
        
        app = matches[0]
        activities = app.get("activity") or []
        if isinstance(activities, str):
            activities = [activities]
        
        print(f"Activities for {app['label']} ({app['pkg']}):")
        if not activities:
            print("  (no activities indexed)")
        else:
            for i, act in enumerate(activities):
                short_name = act.split(".")[-1] if "." in act else act
                print(f"  [{i + 1}] {short_name}")
                if debug:
                    print(f"      {act}")
        sys.exit(0)
    
    specific_activity = None
    if "--activity" in args:
        idx = args.index("--activity")
        if idx + 1 < len(args):
            specific_activity = args[idx + 1]
            args = args[:idx] + args[idx + 2:]
    
    query = " ".join(args)
    
    index = load_index()
    if not index:
        print("No app index found. Run: launch --reindex", file=sys.stderr)
        sys.exit(1)
    
    matches = search_apps(query, index)
    
    if not matches:
        print(f"No apps found matching '{query}'", file=sys.stderr)
        sys.exit(1)
    
    if len(matches) == 1 or matches[0]["ratio"] >= 0.8:
        app = matches[0]
        print(f"Launching: {app['label']}")
        if debug:
            print(f"[DEBUG] Package: {app['pkg']}")
            activities = app.get("activity") or []
            if isinstance(activities, str):
                activities = [activities]
            print(f"[DEBUG] Activities: {activities}")
        
        if specific_activity:
            activities = app.get("activity") or []
            if isinstance(activities, str):
                activities = [activities]
            
            if specific_activity.isdigit():
                idx = int(specific_activity) - 1
                if 0 <= idx < len(activities):
                    specific_activity = activities[idx]
                else:
                    print(f"Invalid activity index: {specific_activity}", file=sys.stderr)
                    sys.exit(1)
            elif "." not in specific_activity and activities:
                for act in activities:
                    if act.endswith("." + specific_activity) or act == specific_activity:
                        specific_activity = act
                        break
            
            launch_app(app["pkg"], [specific_activity], debug=debug)
        else:
            launch_app(app["pkg"], app.get("activity"), debug=debug)
    else:
        print(f"Multiple matches for '{query}':")
        for i, app in enumerate(matches[:3]):
            print(f"  [{i + 1}] {app['label']} ({app['pkg']}) - {app['ratio']:.0%} match")
        
        try:
            choice = input("Select (1-3) or Enter to cancel: ").strip()
            if choice in ("1", "2", "3"):
                idx = int(choice) - 1
                if idx < len(matches):
                    app = matches[idx]
                    print(f"Launching: {app['label']}")
                    launch_app(app["pkg"], app.get("activity"), debug=debug)
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled")


if __name__ == "__main__":
    main()
